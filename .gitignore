# ── Sensitive config files — NEVER commit these ──
config/db.php
config/salesforce.php
config/razorpay.php

# ── Environment files ──
.env
*.env

# ── Test/debug files ──
test.php
debug.php
phpinfo.php

# ── Uploaded user content ──
uploads/videos/*
uploads/notes/*
!uploads/videos/.gitkeep
!uploads/notes/.gitkeep

# ── PHP error logs ──
*.log
error_log

# ── OS / editor junk ──
.DS_Store
Thumbs.db
.vscode/
*.swp

# ── Zip/backup files ──
*.zip
*.bak
*.backup
