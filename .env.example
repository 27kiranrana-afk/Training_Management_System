# ============================================================
#  Training Management System — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ============================================================

# Database
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=training_system

# Timezone (e.g. Asia/Kolkata, UTC, America/New_York)
APP_TIMEZONE=Asia/Kolkata

# Admin login email (used to restrict admin login tab)
ADMIN_EMAIL=admin@tms.com

# Razorpay (get from razorpay.com → Settings → API Keys)
RZP_KEY_ID=rzp_test_XXXXXXXXXXXX
RZP_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Salesforce (get from Salesforce Setup → App Manager)
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_USERNAME=
SF_PASSWORD=
